# ==========================================

# Application Configuration

# ==========================================

NODE_ENV=development
PORT=8000

# Frontend URL

CLIENT_URL=http://localhost:5173

# ==========================================

# MongoDB Configuration

# ==========================================

MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/CareOS-HospitalCareERP

# ==========================================

# Brevo Email Configuration

# ==========================================

BREVO_API_KEY=your_brevo_api_key

BREVO_SENDER_NAME=CareOS Support
BREVO_SENDER_EMAIL=[noreply@yourdomain.com](mailto:noreply@yourdomain.com)

SUPPORT_RECEIVER_EMAIL=[support@yourdomain.com](mailto:support@yourdomain.com)

# ==========================================

# Google reCAPTCHA Configuration

# ==========================================

RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ==========================================

# JWT Authentication (Future Use)

# ==========================================

JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d
